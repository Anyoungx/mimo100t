# MiMo API Configuration
# Copy this file to .env and fill in your actual values

# MiMo API Key (required)
MIMO_API_KEY=your_api_key_here

# MiMo API Base URL (default: https://api.mimo.com/v1)
MIMO_BASE_URL=https://api.mimo.com/v1

# Model Configuration
MODEL_NAME=mimo-pro
TEMPERATURE=0.7
MAX_TOKENS=2048
CONTEXT_WINDOW=128000

# Request Settings
REQUEST_TIMEOUT=120
MAX_RETRIES=3

# Cache Settings
CACHE_DIR=.mimo_cache
ENABLE_CACHE=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=mimo.log